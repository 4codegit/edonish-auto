# eDonish Auto — Environment Variables
# Copy this file to .env and fill in your credentials

# Your edonish.tj login ID and password
EDONISH_LOGIN=
EDONISH_PASSWORD=

# Grade range (default: 8-10)
EDONISH_MIN_GRADE=8
EDONISH_MAX_GRADE=10

# Parallel workers (default: 4)
EDONISH_WORKERS=4

# Filter options: class name, subject, or quarter. Use "all" for no filter
EDONISH_CLASS=all
EDONISH_SUBJECT=all
EDONISH_QUARTER=all

# Only fill empty cells (true/false)
EDONISH_FILL_EMPTY=true

# Also fill quarter/semester/year marks (true/false)
EDONISH_QUARTER_MARKS=true
